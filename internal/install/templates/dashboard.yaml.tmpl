# Orkano dashboard (M2.2 component deploy, rendered per install). The
# operator-facing control panel: serves the embedded SPA and writes Orkano
# custom resources through its narrow-RBAC orkano-dashboard ServiceAccount
# (INV-01: never cluster-admin). Image tag = the CLI's own version. Unlike the
# receiver it MOUNTS its SA token — it is the one component besides the operator
# that talks to the Kubernetes API.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: orkano-dashboard
  namespace: orkano-system
  labels:
    app.kubernetes.io/name: orkano-dashboard
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: orkano-dashboard
  template:
    metadata:
      labels:
        app.kubernetes.io/name: orkano-dashboard
    spec:
      serviceAccountName: orkano-dashboard
      # Explicit (the default): the dashboard needs its SA token to reach the
      # Kubernetes API — so a copy-paste of the receiver's `false` would silently
      # break it, not just tighten it.
      automountServiceAccountToken: true
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
        runAsGroup: 65532
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: dashboard
          image: {{ .DashboardImage }}
          env:
            # The dashboard's own store (users/sessions/audit/history) as the
            # least-privilege orkano_dashboard role (INV-03: only the DSN, by
            # reference; it holds no user-app secret values).
            - name: ORKANO_DB_DSN
              valueFrom:
                secretKeyRef:
                  name: orkano-dashboard-db
                  key: dsn
            # The app-layer key that encrypts the TOTP seed at rest, so a Postgres
            # dump alone cannot bypass 2FA (the attacker also needs this Secret).
            # Injected via secretKeyRef (the kubelet mounts it), so the dashboard
            # needs no secrets-read RBAC — ADR-0013's value-blind-only grant holds.
            - name: ORKANO_DASHBOARD_ENC_KEY
              valueFrom:
                secretKeyRef:
                  name: orkano-dashboard-enc-key
                  key: key
            # The install-token hash the dashboard checks redemption against, same
            # secretKeyRef-not-RBAC reasoning as above.
            - name: ORKANO_BOOTSTRAP_TOKEN_SHA256
              valueFrom:
                secretKeyRef:
                  name: orkano-bootstrap-token
                  key: token-sha256
          # OIDC sign-in config (ADR-0016), OPTIONAL. The Secret's keys ARE the env
          # var names: ORKANO_OIDC_ISSUER, _CLIENT_ID, _CLIENT_SECRET,
          # _REDIRECT_URL, _ALLOWED_EMAILS, _ALLOWED_GROUPS, and the optional
          # _SCOPES, _GROUPS_CLAIM. optional:true means the dashboard starts with
          # OIDC disabled until the onboarding wizard (M2.6) creates this Secret
          # and rolls the pod — no init flags, fail-closed by absence. The client
          # secret stays in this K8s Secret, never in Postgres. The Secret lives in
          # orkano-system (this pod's namespace) and is admin/wizard-controlled —
          # the dashboard SA can write Secrets only in orkano-apps, so it cannot
          # inject env into its own pod. Explicit env above wins any name clash.
          envFrom:
            - secretRef:
                name: orkano-oidc
                optional: true
          ports:
            - name: http
              containerPort: 8080
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 20
          readinessProbe:
            httpGet:
              path: /readyz
              port: http
            initialDelaySeconds: 3
            periodSeconds: 10
          resources:
            requests:
              cpu: 25m
              memory: 64Mi
            limits:
              memory: 128Mi
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop: [ALL]
          volumeMounts:
            - name: tmp
              mountPath: /tmp
      volumes:
        # readOnlyRootFilesystem (ADR-0007) with a writable /tmp for scratch.
        - name: tmp
          emptyDir: {}
---
# ClusterIP only: the dashboard is never internet-reachable by default (INV-05).
# Access is the onboarding wizard's job (orkano proxy / Tailscale / IAP); there
# is deliberately no Ingress.
apiVersion: v1
kind: Service
metadata:
  name: orkano-dashboard
  namespace: orkano-system
  labels:
    app.kubernetes.io/name: orkano-dashboard
spec:
  selector:
    app.kubernetes.io/name: orkano-dashboard
  ports:
    - name: http
      port: 80
      targetPort: http
