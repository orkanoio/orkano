# The app-facing ACME ClusterIssuer (ADR-0006). Every Domain Ingress the
# operator renders is annotated with this issuer name (orkano-platform, the
# operator's --cluster-issuer default), and cert-manager's ingress-shim issues
# the certificate. Let's Encrypt staging by default (PLANNING risk #7 — avoids
# burning prod rate limits in dev); --acme-prod selects production. Distinct
# from the namespaced internal-CA Issuer that signs the registry's TLS.
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: orkano-platform
spec:
  acme:
    server: {{ .ACMEServer }}
{{- if .ACMEEmail }}
    email: {{ .ACMEEmail }}
{{- end }}
    privateKeySecretRef:
      name: orkano-platform-acme-account
    solvers:
      - http01:
          ingress:
            # k3s's bundled ingress controller.
            class: traefik
